# Copy to .env. For `agent-tag serve`, you can set connection creds here OR (easier)
# leave them blank and enter them in the admin console at http://localhost:8765.
# The zero-cred console demo (`agent-tag run --adapter console --backend echo`) needs nothing.

# --- Infra (serve) ---
AGENT_TAG_WEB_HOST=0.0.0.0       # 127.0.0.1 for local-only; 0.0.0.0 in Docker
AGENT_TAG_WEB_PORT=8765
AGENT_TAG_DB=agent_tag.db        # sqlite path (Docker overrides to /data/agent_tag.db)
AGENT_TAG_ADMIN_TOKEN=           # set this to require a token to open the console
AGENT_TAG_REDACTION=1            # 1 to enable outbound redaction/DLP

# --- Which chat platforms to run (serve) ---
AGENT_TAG_ADAPTER=lark           # first enabled platform: lark | slack | discord
AGENT_TAG_BACKEND=claude         # default backend for new channels: echo | claude | openai | cli
AGENT_TAG_MODEL=                 # e.g. claude-opus-4-8 (backend-specific)

# --- Backends ---
# BYO metered API key (the compliant path for a shared/hosted bot):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Coding-plan via YOUR local CLI (self-host only — uses your own plan; hosted/multi-tenant must use an API key):
AGENT_TAG_CLI_COMMAND=claude     # or: codex

# --- Lark (international) ---
LARK_APP_ID=
LARK_APP_SECRET=
LARK_DOMAIN=https://open.larksuite.com   # Feishu: https://open.feishu.cn

# --- Slack (optional) ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- Discord (optional) ---
DISCORD_TOKEN=
